TG_API_ID=123456
TG_API_HASH=abcdef0123456789abcdef0123456789
TG_PHONE=+1xxxxxxxxxx
TARGET_BOT=@YourRatesBot
ALERT_BOT_TOKEN=
ALERT_CHAT_ID=
OUTPUT_JSON=rates.json

# Boros TypeScript trader
BOROS_MODE=paper
BOROS_API_BASE_URL=https://api.boros.finance/core
BOROS_SQLITE_PATH=data/boros_trader.sqlite
BOROS_POLLING_INTERVAL_MS=60000
BOROS_STARTING_EQUITY_USD=100000
BOROS_MIN_DAYS_TO_MATURITY=14
BOROS_MIN_EDGE_BPS=150
BOROS_EXIT_EDGE_BPS=50
BOROS_AGGRESSIVE_ENTRY_BPS=300
BOROS_MAX_INITIAL_MARGIN_PCT_PER_MARKET=0.10
BOROS_MAX_TOTAL_INITIAL_MARGIN_PCT=0.35
BOROS_MAX_CONCURRENT_MARKETS=3
BOROS_MAX_EFFECTIVE_LEVERAGE=1.5
BOROS_MARGIN_UTILIZATION_TARGET_PCT=0.85
BOROS_MIN_ORDER_NOTIONAL_USD=10
BOROS_ALLOWED_MARKET_IDS=
BOROS_ALLOW_ISOLATED_MARKETS=true
BOROS_AUTO_FUND_ISOLATED_MARKETS=true
BOROS_ISOLATED_MARGIN_BUFFER_BPS=500
BOROS_MIN_ISOLATED_CASH_TOPUP_USD=10
BOROS_AUTO_CANCEL_STALE_LIVE_ORDERS=true
BOROS_LIVE_ENTRY_ORDER_TTL_SECONDS=600
BOROS_LIVE_EXIT_ORDER_TTL_SECONDS=180
BOROS_MIN_LIQUIDITY_COVERAGE=3
BOROS_MIN_ENTRY_LIQ_BUFFER_BPS=400
BOROS_MIN_MAINTAIN_LIQ_BUFFER_BPS=200
BOROS_MAX_DAILY_DRAWDOWN_PCT=0.03
BOROS_MAX_FAILURE_STREAK=2
BOROS_CLIP_APR_WINDOW_BPS=500
BOROS_MARKET_ORDER_SLIPPAGE=0.05
BOROS_TAKE_PROFIT_PCT=0.25
BOROS_STOP_LOSS_PCT=0.15
BOROS_TRAILING_STOP_ARM_PCT=0.15
BOROS_TRAILING_STOP_GIVEBACK_PCT=0.10
BOROS_PAPER_ASSUME_TAKER_ENTRY=true
BOROS_DRY_RUN=false

# Required only for BOROS_MODE=live
BOROS_RPC_URL=
BOROS_ACCOUNT_ID=
BOROS_ROOT_ADDRESS=
BOROS_PRIVATE_KEY=

# Velocity Monitor (Hyperliquid WebSocket price spike detection)
BOROS_VELOCITY_ENABLED=true
BOROS_VELOCITY_WINDOW_MS=120000
BOROS_VELOCITY_THRESHOLD_PCT=0.03
BOROS_VELOCITY_ALERT_COOLDOWN_MS=300000
BOROS_VELOCITY_RECONNECT_DELAY_MS=5000

# Copy Trade Mode
BOROS_COPY_TRADE_ENABLED=false
BOROS_COPY_TRADE_TARGET_ADDRESS=0x0000000000000000000000000000000000000000
BOROS_COPY_TRADE_TARGET_ACCOUNT_ID=
BOROS_COPY_TRADE_POLLING_MS=10000
BOROS_COPY_TRADE_SIZE_RATIO=1.0
BOROS_COPY_TRADE_MAX_NOTIONAL_USD=5000
BOROS_COPY_TRADE_MAX_SLIPPAGE=0.10
BOROS_COPY_TRADE_ROUND_UP_TO_MIN=true

{
  "name": "boros-relative-value-trader",
  "version": "0.1.0",
  "private": true,
  "description": "Relative-value Boros trader with paper mode, SQLite logging, and Boros SDK execution",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "start": "tsx src/index.ts",
    "start:once": "tsx src/index.ts --once",
    "test": "vitest run",
    "test:watch": "vitest",
    "ui": "cd ui && npm run dev",
    "ui:build": "cd ui && npm run build",
    "ui:install": "cd ui && npm install",
    "boros": "tsx src/cli.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@pendle/sdk-boros": "^1.1.40",
    "better-sqlite3": "^11.10.0",
    "dotenv": "^16.6.1",
    "viem": "2.44.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.0.15",
    "@types/ws": "^8.18.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
